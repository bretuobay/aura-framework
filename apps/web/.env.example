# =============================================================================
# AURA E-Commerce Demo — Environment Variables
# =============================================================================
# Copy this file to .env.local and adjust values as needed.
# All NEXT_PUBLIC_ vars are accessible on both server and client side.
# =============================================================================

# --- Simulation Flags --------------------------------------------------------
# Controls whether the app uses real AI services or operates in simulation mode.

# Use real LLM (via OpenRouter) for adaptation reasoning (default: false)
NEXT_PUBLIC_USE_REAL_LLM=false

# Use real SLM for classification tasks (default: false)
NEXT_PUBLIC_USE_REAL_SLM=false

# Apply predefined prescriptions regardless of AI availability (default: false)
NEXT_PUBLIC_SIMULATE_ADAPTATIONS=false

# Show Devtools Overlay on initial page load (default: false)
NEXT_PUBLIC_SHOW_DEVTOOLS=false

# Display explanation panels alongside adaptations (default: true)
NEXT_PUBLIC_ENABLE_EXPLANATIONS=true

# Display consent controls in the UI (default: true)
NEXT_PUBLIC_ENABLE_CONSENT=true

# --- AI Provider Configuration -----------------------------------------------
# Required only when USE_REAL_LLM or USE_REAL_SLM is true.

# API key for the LLM provider (OpenRouter or OpenAI-compatible)
OPENROUTER_API_KEY=

# Model identifier (e.g., "openai/gpt-4o", "anthropic/claude-3.5-sonnet")
OPENROUTER_MODEL=openai/gpt-4o

# Provider base URL (default: OpenRouter)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
