{
  "name": "aura-framework",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\" \"packages/*/__tests__/**/*.{ts,tsx}\" \"packages/*/tests/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx}\" \"packages/*/__tests__/**/*.{ts,tsx}\" \"packages/*/tests/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fast-check": "^4.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.2.1"
  }
}
