{
  "name": "@aura/devtools",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --declarationDir ./dist",
    "test": "vitest run",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "@aura/protocol": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "hono": "^4.4.0",
    "vite": "^6.3.5",
    "vitest": "^2.0.0",
    "fast-check": "^3.19.0",
    "@testing-library/react": "^16.0.0",
    "zod": "^3.23.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "jsdom": "^26.1.0",
    "typescript": "^5.4.0"
  }
}
