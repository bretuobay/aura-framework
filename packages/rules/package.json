{
  "name": "@aura/rules",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "aura-rules": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "package.json"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@aura/protocol": "workspace:*",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "fast-check": "^4.1.1",
    "tsup": "^8.5.0",
    "vitest": "^3.2.1"
  }
}
